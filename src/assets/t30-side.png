<script nonce="HbcOpTzUGAG9kg1sGbGIRvtcY4CXF56T" type="text/javascript">document.addEventListener('DOMContentLoaded',function(){let address="/institucional/politica-de-privacidade";document.querySelectorAll("[for*='declaro-que-li-e-concordo']").forEach(function(el){if(el){let linkEl=el.querySelector('a');if(linkEl){linkEl.href='';linkEl.href=address;linkEl.target='_blank';}}});});</script>
